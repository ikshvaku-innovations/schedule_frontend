# ============================================================
# Environment Variables — DO NOT hardcode secrets here!
# ============================================================
# All values are provided by Azure Static Web Apps at BUILD time.
# Set them in: Azure Portal > Static Web App > Configuration > Application Settings
#
# For local development, create a `.env.local` file (also gitignored)
# and add your values there. Vite loads .env.local automatically.
# ============================================================

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Gemini
VITE_GEMINI_API_KEY=

# Google Cloud Storage
VITE_GCS_BUCKET_NAME=
VITE_GCS_CLIENT_EMAIL=
VITE_GCS_PRIVATE_KEY=
VITE_GCS_PROJECT_ID=